# ============================================
# NotifyEngine Environment Variables
# ============================================

# Database
DATABASE_URL=postgresql://notify:notify@localhost:5432/notifyengine
POSTGRES_USER=notify
POSTGRES_PASSWORD=notify
POSTGRES_DB=notifyengine

# Redis
REDIS_URL=redis://localhost:6379
# Dedicated Redis pub/sub connection for the dashboard bridge.
# May point at the same instance as REDIS_URL — Socket.IO/BullMQ require
# subscriber clients to be isolated from command clients.
REDIS_PUBSUB_URL=redis://localhost:6379

# ML Service
ML_SERVICE_URL=http://localhost:8000

# API Server
PORT=3000
NODE_ENV=development

# Security
WEBHOOK_HMAC_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Email (Mailpit for local dev — SMTP 1025, UI at http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# SMS (dev — use mock provider)
SMS_PROVIDER=mock

# Dashboard
DASHBOARD_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug
